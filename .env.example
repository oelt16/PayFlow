# Copy to `.env` in the repo root (optional) and adjust. Used by `infra/docker-compose.yml`.

# PostgreSQL
POSTGRES_USER=payflow
POSTGRES_PASSWORD=payflow
POSTGRES_DB=payflow
POSTGRES_PORT=5432

# Kafka — apache/kafka image (host port; clients inside Compose use kafka:9092)
KAFKA_PORT=9092

# Kafka UI (spec: browse at localhost:8080)
KAFKA_UI_PORT=8080

# Backend HTTP ports on the host
PAYMENT_SERVICE_PORT=8081
MERCHANT_SERVICE_PORT=8082
WEBHOOK_SERVICE_PORT=8083

# Dashboard (nginx serves SPA and proxies /api to backends)
FRONTEND_PORT=3000
